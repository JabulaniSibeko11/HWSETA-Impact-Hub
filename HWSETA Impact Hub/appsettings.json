{
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\MSSQLLocalDB;Database=HWSETA_Impact_Hub_DB;Trusted_Connection=true;TrustServerCertificate=true;MultipleActiveResultSets=true;"
  },

  "App": {
    "PublicBaseUrl": "https://localhost:7045",
    "ApplicationName": "HWSETA Impact Hub"
  },

  "ProofUploads": {
    "CompletionLettersRootPath": "C:\\HWSETA\\Completion Letters",
    "MaxFileSizeBytes": 10485760,
    "AllowedExtensions": [ ".pdf" ]
  },

  "Email": {
    "FromAddress": "no-reply@hwseta.org.za",
    "FromName": "HWSETA Impact Hub",
    "Smtp": {
      "Host": "168.89.180.38",
      "Port": 25,
      "EnableSsl": false,
      "Username": "no-reply@hwseta.org.za",
      "Password": "",
      "UseDefaultCredentials": false
    }
  },

  "Sms": {
    "Enabled": false,
    "Provider": "Gateway",
    "DefaultSenderId": "HWSETA",
    "Gateway": {
      "BaseUrl": "https://YOUR-SMS-GATEWAY/api",
      "ApiKey": "",
      "ApiSecret": "",
      "SendPath": "/send",
      "AuthHeaderName": "Authorization",
      "AuthHeaderValuePrefix": "Bearer "
    }
  },

  "Security": {
    "Roles": [
      "Admin",
      "ProgrammeManager",
      "ExecutiveReadOnly",
      "Beneficiary"
    ],

    "Policies": {
      "AdminOnly": [ "Admin" ],
      "AdminManage": [ "Admin", "ProgrammeManager" ],
      "ExecRead": [ "Admin", "ProgrammeManager", "ExecutiveReadOnly" ],
      "BeneficiaryOnly": [ "Beneficiary" ]
    },

    "Registration": {
      "AllowPublicRegistration": false,
      "DefaultRole": "Beneficiary"
    },

    "BootstrapAdmin": {
      "Email": "admin@hwseta.org.za",
      "Password": "ChangeMe!12345",
      "RequireConfirmedEmail": false
    },

    "LoginRedirects": {
      "AdminDefaultController": "Admin",
      "AdminDefaultAction": "Index",
      "BeneficiaryDefaultController": "BeneficiaryPortal",
      "BeneficiaryDefaultAction": "Index"
    },

    "AdminMenu": [
      {
        "Title": "1) Dashboard",
        "Controller": "Admin",
        "Action": "Index",
        "Policy": "AdminManage"
      },
      {
        "Title": "2) Setup: Programmes",
        "Controller": "Programmes",
        "Action": "Index",
        "Policy": "AdminManage"
      },
      {
        "Title": "3) Setup: Employers",
        "Controller": "Employers",
        "Action": "Index",
        "Policy": "AdminManage"
      },
      {
        "Title": "4) Setup: Service Providers",
        "Controller": "Providers",
        "Action": "Index",
        "Policy": "AdminManage"
      },
      {
        "Title": "5) Setup: Cohorts",
        "Controller": "Cohorts",
        "Action": "Index",
        "Policy": "AdminManage"
      },
      {
        "Title": "6) Onboarding: Beneficiaries",
        "Controller": "Beneficiaries",
        "Action": "Index",
        "Policy": "AdminManage"
      },
      {
        "Title": "7) Enrolment & Tracking",
        "Controller": "Enrollments",
        "Action": "Index",
        "Policy": "AdminManage"
      },
      {
        "Title": "8) Monitoring Forms (Builder/Publish/Send)",
        "Controller": "FormTemplates",
        "Action": "Index",
        "Policy": "AdminManage"
      },
      {
        "Title": "9) Form Submissions",
        "Controller": "FormSubmissions",
        "Action": "Index",
        "Policy": "AdminManage"
      },
      {
        "Title": "10) Reporting",
        "Controller": "Reports",
        "Action": "Index",
        "Policy": "ExecRead"
      },
      {
        "Title": "11) User Management",
        "Controller": "AdminUsers",
        "Action": "Create",
        "Policy": "AdminOnly"
      },
      {
        "Title": "12) Communication Center",
        "Controller": "Chat",
        "Action": "Index",
        "Policy": "AdminManage"
      },
      {
        "Title": "13) Beneficiary Feedback",
        "Controller": "Feedback",
        "Action": "Index",
        "Icon": "bi-chat-square-text",
        "Policy": "AdminManage"
      },
      {
        "Title": "14) Feed & Notifications",
        "Controller": "Notifications",
        "Action": "Index",
        "Icon": "bi-bell",
        "Policy": "AdminManage"
      }
    ],

    "BeneficiaryMenu": [
      {
        "Title": "1) My Dashboard",
        "Controller": "BeneficiaryPortal",
        "Action": "Index",
        "Icon": "bi-speedometer2",
        "Policy": "BeneficiaryOnly"
      },
      {
        "Title": "2) My Forms",
        "Controller": "BeneficiaryForms",
        "Action": "Index",
        "Icon": "bi-file-earmark-text",
        "Policy": "BeneficiaryOnly"
      },
      {
        "Title": "3) My Messages",
        "Controller": "BeneficiaryMessages",
        "Action": "Index",
        "Icon": "bi-chat-dots",
        "Policy": "BeneficiaryOnly"
      },
      {
        "Title": "4) My Enrolments",
        "Controller": "BeneficiaryEnrollments",
        "Action": "Index",
        "Icon": "bi-mortarboard",
        "Policy": "BeneficiaryOnly"
      },
      {
        "Title": "5) My Profile",
        "Controller": "BeneficiaryProfile",
        "Action": "Index",
        "Icon": "bi-person-circle",
        "Policy": "BeneficiaryOnly"
      },
      {
        "Title": "6) Notifications",
        "Controller": "BeneficiaryNotifications",
        "Action": "Index",
        "Icon": "bi-bell",
        "Policy": "BeneficiaryOnly"
      }
    ]
  },

  "BeneficiaryPortal": {
    "Dashboard": {
      "RecentFormsTake": 5,
      "RecentMessagesTake": 5,
      "RecentEnrollmentsTake": 5,
      "RecentActivityTake": 8
    },
    "Forms": {
      "DefaultExpiryDays": 14,
      "AllowResumeDrafts": true
    },
    "Messages": {
      "EnableTwoWayChat": true,
      "AllowBeneficiaryReplies": true
    },
    "Notifications": {
      "EnableFeed": true,
      "UnreadBadgeEnabled": true
    }
