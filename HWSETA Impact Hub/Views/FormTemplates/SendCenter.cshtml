@model HWSETA_Impact_Hub.Models.ViewModels.Forms.SendCenterVm
@using HWSETA_Impact_Hub.Domain.Entities

@{
    ViewData["Title"] = "Send Centre";
}

<div style="display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:18px;flex-wrap:wrap;gap:12px;">
    <div>
        <div class="hw-page-eyebrow"><i class="bi bi-send me-1"></i>Form Operations</div>
        <h1 class="hw-page-title">Send <span>Centre</span></h1>
        <p class="hw-page-desc">Filter beneficiaries, preview recipients, then send single or bulk invites.</p>
    </div>
    <a asp-action="Index" class="hw-btn-outline" style="margin-top:4px;">
        <i class="bi bi-arrow-left"></i> Back to Forms
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="hw-card" style="margin-bottom:16px;">
    <div class="hw-card-head">
        <div class="hw-card-icon gold"><i class="bi bi-funnel"></i></div>
        <div>
            <div class="hw-card-title">Choose Template + Filters</div>
            <div class="hw-card-sub">Preview shows top 50 matches. Bulk send will send to all matches.</div>
        </div>
    </div>

    <div class="hw-card-body">
        <form asp-action="PreviewSend" method="post">
            @Html.AntiForgeryToken()

            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">Published Template</label>
                    <select class="form-select" name="SelectedTemplateId">
                        @foreach (var t in Model.Templates)
                        {
                            <option value="@t.TemplateId" selected="@(t.TemplateId == Model.SelectedTemplateId)">
                                @t.Title (@t.Purpose)
                            </option>
                        }
                    </select>
                </div>

                <div class="col-md-3">
                    <label class="form-label">Status</label>
                    <select class="form-select" name="Filters.Status">
                        <option value="">(Any)</option>
                        @foreach (var s in Enum.GetValues(typeof(BeneficiaryRegistrationStatus)).Cast<BeneficiaryRegistrationStatus>())
                        {
                            <option value="@((int)s)" selected="@(Model.Filters.Status.HasValue && (int)Model.Filters.Status.Value == (int)s)">
                                @s
                            </option>
                        }
                    </select>
                </div>

                <div class="col-md-3">
                    <label class="form-label">Province</label>
                    <select class="form-select" name="Filters.ProvinceId">
                        <option value="">(Any)</option>
                        @foreach (var p in Model.Filters.Provinces)
                        {
                            <option value="@p.Value" selected="@(p.Value == (Model.Filters.ProvinceId?.ToString() ?? ""))">
                                @p.Text
                            </option>
                        }
                    </select>
                </div>

                <div class="col-md-4">
                    <label class="form-label">Qualification Type</label>
                    <select class="form-select" name="Filters.QualificationTypeId">
                        <option value="">(Any)</option>
                        @foreach (var x in Model.Filters.QualificationTypes)
                        {
                            <option value="@x.Value" selected="@(x.Value == (Model.Filters.QualificationTypeId?.ToString() ?? ""))">
                                @x.Text
                            </option>
                        }
                    </select>
                </div>

                <div class="col-md-4">
                    <label class="form-label">Programme</label>
                    <select class="form-select" name="Filters.ProgrammeId">
                        <option value="">(Any)</option>
                        @foreach (var x in Model.Filters.Programmes)
                        {
                            <option value="@x.Value" selected="@(x.Value == (Model.Filters.ProgrammeId?.ToString() ?? ""))">
                                @x.Text
                            </option>
                        }
                    </select>
                </div>

                <div class="col-md-4">
                    <label class="form-label">Training Provider</label>
                    <select class="form-select" name="Filters.ProviderId">
                        <option value="">(Any)</option>
                        @foreach (var x in Model.Filters.Providers)
                        {
                            <option value="@x.Value" selected="@(x.Value == (Model.Filters.ProviderId?.ToString() ?? ""))">
                                @x.Text
                            </option>
                        }
                    </select>
                </div>

                <div class="col-md-4">
                    <label class="form-label">Employer</label>
                    <select class="form-select" name="Filters.EmployerId">
                        <option value="">(Any)</option>
                        @foreach (var x in Model.Filters.Employers)
                        {
                            <option value="@x.Value" selected="@(x.Value == (Model.Filters.EmployerId?.ToString() ?? ""))">
                                @x.Text
                            </option>
                        }
                    </select>
                </div>

                <div class="col-md-8">
                    <label class="form-label">Search</label>
                    <input class="form-control" name="Filters.Search" value="@Model.Filters.Search"
                           placeholder="Name / Email / Mobile / ID" />
                </div>

                <div class="col-md-6 d-flex align-items-end gap-3">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" name="Filters.OnlyNotInvitedYet" value="true"
                               @(Model.Filters.OnlyNotInvitedYet ? "checked" : "") />
                        <label class="form-check-label">Only not invited yet</label>
                    </div>

                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" name="Filters.OnlyMissingPasswordOrUser" value="true"
                               @(Model.Filters.OnlyMissingPasswordOrUser ? "checked" : "") />
                        <label class="form-check-label">Only missing password/user</label>
                    </div>
                </div>

                <div class="col-md-6 d-flex align-items-end gap-3">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" name="Filters.SendEmail" value="true"
                               @(Model.Filters.SendEmail ? "checked" : "") />
                        <label class="form-check-label">Send Email</label>
                    </div>

                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" name="Filters.SendSms" value="true"
                               @(Model.Filters.SendSms ? "checked" : "") />
                        <label class="form-check-label">Send SMS</label>
                    </div>
                </div>

                <div class="col-md-12 d-flex align-items-end justify-content-end gap-2">
                    <button type="submit" class="hw-btn-outline">
                        <i class="bi bi-search"></i> Preview
                    </button>
                </div>
            </div>
        </form>

        <hr />

        <form asp-action="SendBulkNow" method="post">
            @Html.AntiForgeryToken()

            <input type="hidden" name="TemplateId" value="@Model.SelectedTemplateId" />

            <input type="hidden" name="Status" value="@Model.Filters.Status" />
            <input type="hidden" name="ProvinceId" value="@Model.Filters.ProvinceId" />
            <input type="hidden" name="QualificationTypeId" value="@Model.Filters.QualificationTypeId" />
            <input type="hidden" name="ProgrammeId" value="@Model.Filters.ProgrammeId" />
            <input type="hidden" name="ProviderId" value="@Model.Filters.ProviderId" />
            <input type="hidden" name="EmployerId" value="@Model.Filters.EmployerId" />
            <input type="hidden" name="Search" value="@Model.Filters.Search" />

            <input type="hidden" name="OnlyNotInvitedYet" value="@(Model.Filters.OnlyNotInvitedYet)" />
            <input type="hidden" name="OnlyMissingPasswordOrUser" value="@(Model.Filters.OnlyMissingPasswordOrUser)" />
            <input type="hidden" name="SendEmail" value="@(Model.Filters.SendEmail)" />
            <input type="hidden" name="SendSms" value="@(Model.Filters.SendSms)" />

            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <b>Matches:</b> @Model.PreviewTotal
                    <span style="color:var(--hw-muted);font-size:12px;">(Preview shows top 50)</span>
                </div>
                <button class="hw-btn-gold" type="submit">
                    <i class="bi bi-send"></i> Send Bulk Now
                </button>
            </div>
        </form>
    </div>
</div>

<div class="hw-table-card">
    <div class="hw-table-card-head">
        <span class="hw-table-card-title"><i class="bi bi-people"></i> Preview Recipients</span>
    </div>

    <div style="overflow-x:auto;">
        <table class="hw-dt">
            <thead>
                <tr>
                    <th>Beneficiary</th>
                    <th>Email</th>
                    <th>Mobile</th>
                    <th>Province</th>
                    <th>Programme</th>
                    <th>Provider</th>
                    <th>Employer</th>
                    <th>Status</th>
                    <th>Invited</th>
                    <th>Send One</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.PreviewRows != null && Model.PreviewRows.Count > 0)
                {
                    foreach (var r in Model.PreviewRows)
                    {
                        <tr>
                            <td>@r.FullName</td>
                            <td>@r.Email</td>
                            <td>@r.Mobile</td>
                            <td>@r.Province</td>
                            <td>@r.Programme</td>
                            <td>@r.TrainingProvider</td>
                            <td>@r.Employer</td>
                            <td>@r.RegistrationStatus</td>
                            <td>@(r.InvitedAt.HasValue? r.InvitedAt.Value.ToString("dd MMM yyyy") : "-")</td>
                            <td>
                                <form asp-action="SendOne" method="post" style="display:inline;">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="templateId" value="@Model.SelectedTemplateId" />
                                    <input type="hidden" name="beneficiaryId" value="@r.BeneficiaryId" />
                                    <input type="hidden" name="sendEmail" value="true" />
                                    <input type="hidden" name="sendSms" value="true" />
                                    <button class="hw-btn-outline" type="submit">
                                        <i class="bi bi-send"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="10" style="color:var(--hw-muted);padding:14px;">
                            No preview results yet. Set filters and click <b>Preview</b>.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

