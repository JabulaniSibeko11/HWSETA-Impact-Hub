@model HWSETA_Impact_Hub.Models.ViewModels.BeneficiaryPortal.BeneficiaryDashboardVm
@{
    ViewData["Title"] = "My Dashboard";
}

<link rel="stylesheet" href="~/css/beneficiarycreatecss.css" />

<div class="hw-page-head">
    <div>
        <div class="hw-page-eyebrow">
            <i class="bi bi-person-circle"></i> Beneficiary Portal
        </div>
        <h1 class="hw-page-title">Welcome, <span>@Model.BeneficiaryName</span></h1>
        <p class="hw-page-desc">
            Track your forms, messages, enrolments, and latest updates in one place.
        </p>
    </div>
</div>

<div class="hw-stat-grid">
    <div class="hw-stat-card">
        <div class="hw-stat-label">Pending Forms</div>
        <div class="hw-stat-value">@Model.PendingFormsCount</div>
    </div>
    <div class="hw-stat-card">
        <div class="hw-stat-label">Unread Messages</div>
        <div class="hw-stat-value">@Model.UnreadMessagesCount</div>
    </div>
    <div class="hw-stat-card">
        <div class="hw-stat-label">Active Enrolments</div>
        <div class="hw-stat-value">@Model.ActiveEnrolmentsCount</div>
    </div>
    <div class="hw-stat-card">
        <div class="hw-stat-label">Pending Actions</div>
        <div class="hw-stat-value">@Model.PendingActionsCount</div>
    </div>
</div>

<div class="hw-card" style="margin-top:20px;">
    <div class="hw-card-head">
        <div class="hw-card-icon green">
            <i class="bi bi-info-circle"></i>
        </div>
        <div>
            <div class="hw-card-title">Profile Status</div>
            <div class="hw-card-sub">Your current beneficiary profile status</div>
        </div>
    </div>
    <div class="hw-card-body">
        <div style="display:flex;gap:12px;flex-wrap:wrap;">
            <span class="hw-status-badge active">@Model.RegistrationStatus</span>
            <span class="hw-status-badge @(Model.IsActive ? "active" : "inactive")">
                @(Model.IsActive ? "Active" : "Inactive")
            </span>
        </div>
    </div>
</div>

<div class="hw-grid-2" style="margin-top:20px;">
    <div class="hw-card">
        <div class="hw-card-head">
            <div class="hw-card-icon gold">
                <i class="bi bi-file-earmark-text"></i>
            </div>
            <div>
                <div class="hw-card-title">My Forms</div>
                <div class="hw-card-sub">Recently assigned forms</div>
            </div>
        </div>
        <div class="hw-card-body">
            @if (!Model.RecentForms.Any())
            {
                <div class="hw-field-hint">No forms assigned yet.</div>
            }
            else
            {
                @foreach (var form in Model.RecentForms)
                {
                    <div style="padding:12px 0;border-bottom:1px solid var(--hw-border);">
                        <div style="font-weight:700;">@form.FormTitle</div>
                        <div style="font-size:12px;color:var(--hw-muted);">@form.Status</div>
                    </div>
                }
            }
        </div>
    </div>

    <div class="hw-card">
        <div class="hw-card-head">
            <div class="hw-card-icon green">
                <i class="bi bi-chat-left-text"></i>
            </div>
            <div>
                <div class="hw-card-title">Messages</div>
                <div class="hw-card-sub">Recent conversations</div>
            </div>
        </div>
        <div class="hw-card-body">
            @if (!Model.RecentMessages.Any())
            {
                <div class="hw-field-hint">No messages yet.</div>
            }
            else
            {
                @foreach (var msg in Model.RecentMessages)
                {
                    <div style="padding:12px 0;border-bottom:1px solid var(--hw-border);">
                        <div style="font-weight:700;">@msg.Subject</div>
                        <div style="font-size:12px;color:var(--hw-muted);">
                            @msg.LastSender · @msg.LastMessageOnUtc.ToLocalTime().ToString("dd MMM yyyy HH:mm")
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</div>

<div class="hw-grid-2" style="margin-top:20px;">
    <div class="hw-card">
        <div class="hw-card-head">
            <div class="hw-card-icon dark">
                <i class="bi bi-mortarboard"></i>
            </div>
            <div>
                <div class="hw-card-title">My Enrolments</div>
                <div class="hw-card-sub">Current programme participation</div>
            </div>
        </div>
        <div class="hw-card-body">
            @if (!Model.ActiveEnrollments.Any())
            {
                <div class="hw-field-hint">No active enrolments found.</div>
            }
            else
            {
                @foreach (var enr in Model.ActiveEnrollments)
                {
                    <div style="padding:12px 0;border-bottom:1px solid var(--hw-border);">
                        <div style="font-weight:700;">@enr.ProgrammeName</div>
                        <div style="font-size:12px;color:var(--hw-muted);">
                            Cohort: @enr.CohortCode · Provider: @enr.ProviderName
                        </div>
                        <div style="font-size:12px;color:var(--hw-muted);">
                            Status: @enr.Status
                        </div>
                    </div>
                }
            }
        </div>
    </div>

    <div class="hw-card">
        <div class="hw-card-head">
            <div class="hw-card-icon gold">
                <i class="bi bi-bell"></i>
            </div>
            <div>
                <div class="hw-card-title">Recent Activity</div>
                <div class="hw-card-sub">Latest updates on your account</div>
            </div>
        </div>
        <div class="hw-card-body">
            @if (!Model.RecentActivity.Any())
            {
                <div class="hw-field-hint">No activity yet.</div>
            }
            else
            {
                @foreach (var item in Model.RecentActivity)
                {
                    <div style="padding:12px 0;border-bottom:1px solid var(--hw-border);">
                        <div style="font-weight:700;">@item.Title</div>
                        <div style="font-size:12px;color:var(--hw-muted);">@item.Description</div>
                        <div style="font-size:11px;color:var(--hw-muted);">
                            @item.OccurredOnUtc.ToLocalTime().ToString("dd MMM yyyy HH:mm")
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</div>