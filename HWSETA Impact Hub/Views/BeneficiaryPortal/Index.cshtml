@model HWSETA_Impact_Hub.Models.ViewModels.BeneficiaryPortal.BeneficiaryDashboardVm
@{
    ViewData["Title"] = "My Dashboard";

    // Avatar initials
    var parts = Model.BeneficiaryName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
    var initials = parts.Length >= 2
        ? $"{parts[0][0]}{parts[^1][0]}"
        : (parts.Length == 1 ? parts[0][0].ToString() : "?");
    initials = initials.ToUpper();

    // Journey progress calculation (5 stages)
    var regStatus = Model.RegistrationStatus?.ToLower() ?? "";
    int journeyStep = regStatus switch
    {
        var s when s.Contains("complet") => 5,
        var s when s.Contains("active") => 4,
        var s when s.Contains("upload") => 3,
        var s when s.Contains("location") => 2,
        var s when s.Contains("set") => 1,
        _ => 0
    };
    int progressPct = (int)Math.Round(journeyStep / 5.0 * 100);

    // Helper: step state
    string StepState(int step) => step < journeyStep ? "done" : (step == journeyStep ? "current" : "pending");

    // Today string
    var today = DateTime.Now.ToString("dddd, dd MMMM yyyy");
}

<link rel="stylesheet" href="~/css/BeneficiaryPortalCss.css" />

@* ── Alerts ─────────────────────────────────────────────────── *@
@if (TempData["Success"] != null)
{
    <div class="bp-alert success">
        <i class="bi bi-check-circle-fill"></i>
        <span>@TempData["Success"]</span>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="bp-alert error">
        <i class="bi bi-exclamation-circle-fill"></i>
        <span>@TempData["Error"]</span>
    </div>
}


<link href="~/css/beneficiaryportalcss.css" rel="stylesheet" />
@* ══ HERO BANNER ════════════════════════════════════════════════ *@
<div class="bp-hero">
    <div class="bp-hero-left">
        <div class="bp-hero-avatar">@initials</div>
        <div class="bp-hero-text">
            <div class="bp-hero-greeting">Welcome back</div>
            <div class="bp-hero-name">@Model.BeneficiaryName</div>
            <div class="bp-hero-tags">
                @if (Model.IsActive)
                {
                    <span class="bp-hero-tag success">
                        <i class="bi bi-patch-check-fill"></i> Active Beneficiary
                    </span>
                }
                else
                {
                    <span class="bp-hero-tag" style="background:rgba(192,57,43,.35);">
                        <i class="bi bi-x-circle"></i> Inactive
                    </span>
                }
                <span class="bp-hero-tag gold">
                    <i class="bi bi-mortarboard-fill"></i> @Model.RegistrationStatus
                </span>
                @if (Model.PendingActionsCount > 0)
                {
                    <span class="bp-hero-tag" style="background:rgba(192,57,43,.35);">
                        <i class="bi bi-exclamation-circle-fill"></i> @Model.PendingActionsCount action@(Model.PendingActionsCount != 1 ? "s" : "") pending
                    </span>
                }
            </div>
        </div>
    </div>
    <div class="bp-hero-right">
        <div class="bp-hero-date">
            <i class="bi bi-calendar3"></i> @today
        </div>
        <div class="bp-hero-desc">
            Track your training journey, forms and messages — all in one place.
        </div>
    </div>
    <div class="bp-hero-strip"></div>
</div>

@* ══ KPI ACTION CARDS ══════════════════════════════════════════ *@
<div class="bp-kpi-grid">

    @* Forms *@
    <a asp-controller="BeneficiaryForms" asp-action="Index" class="bp-kpi-card gold">
        @if (Model.PendingFormsCount > 0)
        {
            <div class="bp-kpi-dot">@(Model.PendingFormsCount > 9 ? "9+" : Model.PendingFormsCount.ToString())</div>
        }
        <div class="bp-kpi-icon gold"><i class="bi bi-file-earmark-text-fill" style="font-family:unset!important"></i></div>
        <div>
            <div class="bp-kpi-number">@Model.PendingFormsCount</div>
            <div class="bp-kpi-label">Pending Forms</div>
        </div>
        <div class="bp-kpi-foot">
            <span>View forms</span>
            <i class="bi bi-arrow-right" style="font-family:unset!important"></i>
        </div>
    </a>

    @* Messages *@
    <a asp-controller="BeneficiaryMessages" asp-action="Index" class="bp-kpi-card green">
        @if (Model.UnreadMessagesCount > 0)
        {
            <div class="bp-kpi-dot">@(Model.UnreadMessagesCount > 9 ? "9+" : Model.UnreadMessagesCount.ToString())</div>
        }
        <div class="bp-kpi-icon green"><i class="bi bi-chat-dots-fill" style="font-family:unset!important"></i></div>
        <div>
            <div class="bp-kpi-number">@Model.UnreadMessagesCount</div>
            <div class="bp-kpi-label">Unread Messages</div>
        </div>
        <div class="bp-kpi-foot">
            <span>Open inbox</span>
            <i class="bi bi-arrow-right" style="font-family:unset!important"></i>
        </div>
    </a>

    @* Enrolments *@
    <a asp-controller="BeneficiaryEnrollments" asp-action="Index" class="bp-kpi-card blue">
        <div class="bp-kpi-icon blue"><i class="bi bi-mortarboard-fill" style="font-family:unset!important"></i></div>
        <div>
            <div class="bp-kpi-number">@Model.ActiveEnrolmentsCount</div>
            <div class="bp-kpi-label">Active Enrolments</div>
        </div>
        <div class="bp-kpi-foot">
            <span>My programmes</span>
            <i class="bi bi-arrow-right" style="font-family:unset!important"></i>
        </div>
    </a>

    @* Pending Actions *@
    <a asp-controller="BeneficiaryProfile" asp-action="Index" class="bp-kpi-card red">
        @if (Model.PendingActionsCount > 0)
        {
            <div class="bp-kpi-dot">@(Model.PendingActionsCount > 9 ? "9+" : Model.PendingActionsCount.ToString())</div>
        }
        <div class="bp-kpi-icon red"><i class="bi bi-lightning-charge-fill" style="font-family:unset!important"></i></div>
        <div>
            <div class="bp-kpi-number">@Model.PendingActionsCount</div>
            <div class="bp-kpi-label">Pending Actions</div>
        </div>
        <div class="bp-kpi-foot">
            <span>My profile</span>
            <i class="bi bi-arrow-right" style="font-family:unset!important"></i>
        </div>
    </a>

</div>

@* ══ MAIN LAYOUT ═══════════════════════════════════════════════ *@
<div class="bp-layout">

    @* ═══ LEFT COLUMN ═══════════════════════════════════════════ *@
    <div>

        @* ── Journey tracker ── *@
        <div class="bp-journey">
            <div class="bp-journey-head">
                <div class="bp-journey-ico">
                    <i class="bi bi-map-fill" style="font-family:unset!important"></i>
                </div>
                <div>
                    <div class="bp-journey-title">My Registration Journey</div>
                    <div class="bp-journey-sub">Track your progress through the beneficiary onboarding process</div>
                </div>
            </div>
            <div class="bp-journey-body">
                <div class="bp-progress-bar-wrap">
                    <div class="bp-progress-track">
                        <div class="bp-progress-fill" style="width:@progressPct%"></div>
                    </div>
                    <div class="bp-progress-pct">@progressPct%</div>
                </div>
                <div class="bp-steps">
                    <div class="bp-step @StepState(1)">
                        <div class="bp-step-dot">
                            @if (StepState(1) == "done")
                            {
                                <i class="bi bi-check-lg" style="font-family:unset!important"></i>
                            }
                            else if (StepState(1) == "current")
                            {

                                <i class="bi bi-circle-fill" style="font-family:unset!important;font-size:6px;"></i>
                            }
                            else
                            {

                                <text>1</text>
                            }
                        </div>
                        <div class="bp-step-info">
                            <div class="bp-step-name">Account Created</div>
                            <div class="bp-step-note">Your beneficiary record has been created by HWSETA.</div>
                        </div>
                    </div>
                    <div class="bp-step @StepState(2)">
                        <div class="bp-step-dot">
                            @if (StepState(2) == "done")
                            {
                                <i class="bi bi-check-lg" style="font-family:unset!important"></i>
                            }
                            else if (StepState(2) == "current")
                            {

                                <i class="bi bi-circle-fill" style="font-family:unset!important;font-size:6px;"></i>
                            }
                            else
                            {

                                <text>2</text>
                            }
                        </div>
                        <div class="bp-step-info">
                            <div class="bp-step-name">Password Set</div>
                            <div class="bp-step-note">Secure your account with a personal password.</div>
                        </div>
                    </div>
                    <div class="bp-step @StepState(3)">
                        <div class="bp-step-dot">
                            @if (StepState(3) == "done")
                            {
                                <i class="bi bi-check-lg" style="font-family:unset!important"></i>
                            }
                            else if (StepState(3) == "current")
                            {

                                <i class="bi bi-circle-fill" style="font-family:unset!important;font-size:6px;"></i>
                            }
                            else
                            {

                                <text>3</text>
                            }
                        </div>
                        <div class="bp-step-info">
                            <div class="bp-step-name">Location Confirmed</div>
                            <div class="bp-step-note">Your province and municipality have been verified.</div>
                        </div>
                    </div>
                    <div class="bp-step @StepState(4)">
                        <div class="bp-step-dot">
                            @if (StepState(4) == "done")
                            {
                                <i class="bi bi-check-lg" style="font-family:unset!important"></i>
                            }
                            else if (StepState(4) == "current")
                            {

                                <i class="bi bi-circle-fill" style="font-family:unset!important;font-size:6px;"></i>
                            }
                            else
                            {

                                <text>4</text>
                            }
                        </div>
                        <div class="bp-step-info">
                            <div class="bp-step-name">Documents Uploaded</div>
                            <div class="bp-step-note">Supporting proof documents are on file.</div>
                        </div>
                    </div>
                    <div class="bp-step @StepState(5)">
                        <div class="bp-step-dot">
                            @if (StepState(5) == "done")
                            {
                                <i class="bi bi-check-lg" style="font-family:unset!important"></i>
                            }
                            else if (StepState(5) == "current")
                            {

                                <i class="bi bi-circle-fill" style="font-family:unset!important;font-size:6px;"></i>
                            }
                            else
                            {

                                <text>5</text>
                            }
                        </div>
                        <div class="bp-step-info">
                            <div class="bp-step-name">Registration Complete</div>
                            <div class="bp-step-note">Fully onboarded and eligible for programmes.</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @* ── My Forms ── *@
        <div class="bp-panel">
            <div class="bp-panel-head">
                <div class="bp-panel-left">
                    <div class="bp-panel-icon gold">
                        <i class="bi bi-file-earmark-text-fill" style="font-family:unset!important"></i>
                    </div>
                    <div>
                        <div class="bp-panel-title">My Forms</div>
                        <div class="bp-panel-sub">Recently assigned monitoring forms</div>
                    </div>
                </div>
                <a asp-controller="BeneficiaryForms" asp-action="Index" class="bp-view-all">
                    All forms <i class="bi bi-arrow-right" style="font-family:unset!important"></i>
                </a>
            </div>
            <div class="bp-panel-body">
                @if (!Model.RecentForms.Any())
                {
                    <div class="bp-empty">
                        <div class="bp-empty-ico">
                            <i class="bi bi-file-earmark" style="font-family:unset!important"></i>
                        </div>
                        <div class="bp-empty-title">No forms assigned yet</div>
                        <div class="bp-empty-sub">Monitoring forms from your administrator will appear here.</div>
                    </div>
                }
                else
                {
                    @foreach (var form in Model.RecentForms.Take(5))
                    {
                        var fStatus = form.Status?.ToLower() ?? "";
                        var fIcoClass = fStatus.Contains("submit") || fStatus.Contains("complet") ? "done"
                        : fStatus.Contains("expir") ? "expired" : "pending";
                        var fPillClass = fStatus.Contains("submit") || fStatus.Contains("complet") ? "bp-pill-done"
                        : fStatus.Contains("expir") ? "bp-pill-expired" : "bp-pill-pending";
                        <div class="bp-form-row">
                            <div class="bp-form-ico @fIcoClass">
                                @if (fIcoClass == "done")
                                {
                                    <i class="bi bi-file-earmark-check-fill" style="font-family:unset!important"></i>
                                }
                                else if (fIcoClass == "expired")
                                {

                                    <i class="bi bi-file-earmark-x-fill" style="font-family:unset!important"></i>
                                }
                                else
                                {

                                    <i class="bi bi-file-earmark-text-fill" style="font-family:unset!important"></i>
                                }
                            </div>
                            <div class="bp-form-body">
                                <div class="bp-form-title">@form.FormTitle</div>
                                <div class="bp-form-meta">
                                    <span class="bp-pill @fPillClass">
                                        <span class="bp-pill-dot"></span>@form.Status
                                    </span>
                                    @if (form.SentOnUtc.HasValue)
                                    {
                                        <span class="bp-form-date">
                                            <i class="bi bi-calendar3" style="font-family:unset!important"></i>
                                            Sent @form.SentOnUtc.Value.ToLocalTime().ToString("dd MMM yyyy")
                                        </span>
                                    }
                                    @if (form.ExpiryOnUtc.HasValue && fIcoClass == "pending")
                                    {
                                        var daysLeft = (form.ExpiryOnUtc.Value - DateTime.UtcNow).Days;
                                        <span class="bp-form-date" style="color:@(daysLeft < 3 ? "var(--hw-red)" : "var(--hw-muted)");">
                                            <i class="bi bi-clock" style="font-family:unset!important"></i>
                                            @(daysLeft < 0 ? "Expired" : $"{daysLeft}d left")
                                        </span>
                                    }
                                </div>
                            </div>
                            <i class="bi bi-chevron-right" style="font-family:unset!important;color:var(--hw-border);font-size:12px;"></i>
                        </div>
                    }
                }
            </div>
        </div>

        @* ── My Messages ── *@
        <div class="bp-panel">
            <div class="bp-panel-head">
                <div class="bp-panel-left">
                    <div class="bp-panel-icon green">
                        <i class="bi bi-chat-dots-fill" style="font-family:unset!important"></i>
                    </div>
                    <div>
                        <div class="bp-panel-title">Messages</div>
                        <div class="bp-panel-sub">Recent conversations from your administrators</div>
                    </div>
                </div>
                <a asp-controller="BeneficiaryMessages" asp-action="Index" class="bp-view-all">
                    All messages <i class="bi bi-arrow-right" style="font-family:unset!important"></i>
                </a>
            </div>
            <div class="bp-panel-body">
                @if (!Model.RecentMessages.Any())
                {
                    <div class="bp-empty">
                        <div class="bp-empty-ico">
                            <i class="bi bi-chat" style="font-family:unset!important"></i>
                        </div>
                        <div class="bp-empty-title">No messages yet</div>
                        <div class="bp-empty-sub">Messages from your HWSETA contact will appear here.</div>
                    </div>
                }
                else
                {
                    @foreach (var msg in Model.RecentMessages.Take(4))
                    {
                        var senderInitials = string.Concat(msg.LastSender.Split(' ').Take(2).Select(w => w.FirstOrDefault())).ToUpper();
                        <a asp-controller="BeneficiaryMessages" asp-action="Thread" asp-route-id="@msg.ThreadId"
                           class="bp-msg-row @(msg.IsUnread ? "unread" : "")">
                            <div class="bp-msg-av">@senderInitials</div>
                            <div class="bp-msg-body">
                                <div class="bp-msg-top">
                                    <span class="bp-msg-subject">@msg.Subject</span>
                                    <span class="bp-msg-time">@msg.LastMessageOnUtc.ToLocalTime().ToString("dd MMM")</span>
                                </div>
                                <div class="bp-msg-from">From: @msg.LastSender</div>
                                <div class="bp-msg-preview">@msg.LastMessagePreview</div>
                            </div>
                            @if (msg.IsUnread)
                            {
                                <span class="bp-pill bp-pill-active" style="flex-shrink:0;">New</span>
                            }
                        </a>
                    }
                }
            </div>
        </div>

        @* ── My Enrolments ── *@
        <div class="bp-panel" style="margin-bottom:0;">
            <div class="bp-panel-head">
                <div class="bp-panel-left">
                    <div class="bp-panel-icon blue">
                        <i class="bi bi-mortarboard-fill" style="font-family:unset!important"></i>
                    </div>
                    <div>
                        <div class="bp-panel-title">My Enrolments</div>
                        <div class="bp-panel-sub">Active programme participation</div>
                    </div>
                </div>
                <a asp-controller="BeneficiaryEnrollments" asp-action="Index" class="bp-view-all">
                    All enrolments <i class="bi bi-arrow-right" style="font-family:unset!important"></i>
                </a>
            </div>
            <div class="bp-panel-body">
                @if (!Model.ActiveEnrollments.Any())
                {
                    <div class="bp-empty">
                        <div class="bp-empty-ico">
                            <i class="bi bi-mortarboard" style="font-family:unset!important"></i>
                        </div>
                        <div class="bp-empty-title">No active enrolments</div>
                        <div class="bp-empty-sub">Your programme enrolments will appear here once assigned.</div>
                    </div>
                }
                else
                {
                    @foreach (var enr in Model.ActiveEnrollments.Take(4))
                    {
                        var eStatus = enr.Status?.ToLower() ?? "";
                        var ePillClass = eStatus.Contains("train") ? "bp-pill-training"
                        : eStatus.Contains("complet") ? "bp-pill-done" : "bp-pill-active";
                        <div class="bp-enrol-row">
                            <div class="bp-enrol-ico">
                                <i class="bi bi-book-fill" style="font-family:unset!important"></i>
                            </div>
                            <div class="bp-enrol-body">
                                <div class="bp-enrol-name">@enr.ProgrammeName</div>
                                <div class="bp-enrol-meta">
                                    <span class="bp-pill @ePillClass">
                                        <span class="bp-pill-dot"></span>@enr.Status
                                    </span>
                                    <span>
                                        <i class="bi bi-building" style="font-family:unset!important"></i>
                                        @enr.ProviderName
                                    </span>
                                    <span>
                                        <i class="bi bi-people-fill" style="font-family:unset!important"></i>
                                        Cohort @enr.CohortCode
                                    </span>
                                    <span>
                                        <i class="bi bi-calendar3" style="font-family:unset!important"></i>
                                        Started @enr.StartDate.ToString("dd MMM yyyy")
                                    </span>
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>

    </div>

    @* ═══ RIGHT SIDEBAR ═════════════════════════════════════════ *@
    <div class="bp-sidebar">

        @* Profile card *@
        <div class="bp-profile-card">
            <div class="bp-profile-hero-bg">
                <div class="bp-profile-av">@initials</div>
                <div class="bp-profile-name">@Model.BeneficiaryName</div>
                <div class="bp-profile-role">HWSETA Beneficiary</div>
                <span class="bp-pill @(Model.IsActive ? "bp-pill-active" : "bp-pill-expired")" style="margin-top:2px;">
                    <span class="bp-pill-dot"></span>
                    @(Model.IsActive ? "Active" : "Inactive")
                </span>
            </div>
            <div class="bp-profile-rows">
                <div class="bp-profile-row">
                    <span class="bp-profile-lbl">Status</span>
                    <span class="bp-profile-val">@Model.RegistrationStatus</span>
                </div>
                <div class="bp-profile-row">
                    <span class="bp-profile-lbl">Enrolments</span>
                    <span class="bp-profile-val">@Model.ActiveEnrolmentsCount active</span>
                </div>
                <div class="bp-profile-row">
                    <span class="bp-profile-lbl">Forms</span>
                    <span class="bp-profile-val">@Model.PendingFormsCount pending</span>
                </div>
                <div class="bp-profile-row">
                    <span class="bp-profile-lbl">Messages</span>
                    <span class="bp-profile-val">@Model.UnreadMessagesCount unread</span>
                </div>
            </div>
            <a asp-controller="BeneficiaryProfile" asp-action="Index" class="bp-profile-action">
                <i class="bi bi-person-gear" style="font-family:unset!important"></i> View My Profile
            </a>
        </div>

        @* Activity Timeline *@
        <div class="bp-panel" style="margin-bottom:0;">
            <div class="bp-panel-head">
                <div class="bp-panel-left">
                    <div class="bp-panel-icon teal">
                        <i class="bi bi-activity" style="font-family:unset!important"></i>
                    </div>
                    <div>
                        <div class="bp-panel-title">Recent Activity</div>
                        <div class="bp-panel-sub">Latest updates on your account</div>
                    </div>
                </div>
            </div>
            <div class="bp-panel-body">
                @if (!Model.RecentActivity.Any())
                {
                    <div class="bp-empty" style="padding:24px 16px;">
                        <div class="bp-empty-ico">
                            <i class="bi bi-clock-history" style="font-family:unset!important"></i>
                        </div>
                        <div class="bp-empty-title">No activity yet</div>
                        <div class="bp-empty-sub">Account events will appear here.</div>
                    </div>
                }
                else
                {
                    <div class="bp-timeline">
                        @{
                            var dotColors = new[] { "green", "gold", "blue", "green", "gold" };
                        }
                        @foreach (var (item, i) in Model.RecentActivity.Take(6).Select((x, idx) => (x, idx)))
                        {
                            <div class="bp-tl-item">
                                <div class="bp-tl-dot @dotColors[i % dotColors.Length]">
                                    <i class="bi bi-lightning-fill" style="font-family:unset!important"></i>
                                </div>
                                <div class="bp-tl-body">
                                    <div class="bp-tl-title">@item.Title</div>
                                    <div class="bp-tl-desc">@item.Description</div>
                                    <div class="bp-tl-time">
                                        <i class="bi bi-clock" style="font-family:unset!important"></i>
                                        @item.OccurredOnUtc.ToLocalTime().ToString("dd MMM yyyy · HH:mm")
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>

        @* HWSETA Notice *@
        <div class="bp-notice">
            <div class="bp-notice-ico">
                <i class="bi bi-shield-fill-check" style="font-family:unset!important"></i>
            </div>
            <div>
                <div class="bp-notice-title">Your data is protected</div>
                <div class="bp-notice-text">
                    HWSETA processes your personal information in line with the Protection of Personal
                    Information Act (POPIA). Contact your administrator if you have any concerns.
                </div>
            </div>
        </div>

    </div>
</div>
