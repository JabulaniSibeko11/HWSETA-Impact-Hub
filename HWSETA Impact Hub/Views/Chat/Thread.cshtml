@model HWSETA_Impact_Hub.Models.ViewModels.Chats.ChatThreadVm
@{
    ViewData["Title"] = "Conversation";
}

<link rel="stylesheet" href="~/css/beneficiarycreatecss.css" />

<div class="hw-page-head">
    <div>
        <div class="hw-page-eyebrow">
            <i class="bi bi-chat-left-text"></i> Communication
        </div>

        <h1 class="hw-page-title">@Model.Subject</h1>

        <p class="hw-page-desc">
            @Model.BeneficiaryName
        </p>
    </div>

    <a asp-action="Index" class="hw-btn-outline">
        Back
    </a>
</div>

<div class="hw-card">
    <div class="hw-card-head">
        <div class="hw-card-icon gold">
            <i class="bi bi-chat"></i>
        </div>

        <div>
            <div class="hw-card-title">Conversation</div>
        </div>
    </div>

    <div class="hw-card-body">
        @foreach (var msg in Model.Messages)
        {
            <div style="margin-bottom:16px;padding:14px;border:1px solid var(--hw-border);border-radius:12px;background:@(msg.IsMine ? "var(--hw-green-light)" : "#fff");">
                <strong>@msg.SenderDisplayName</strong>

                <div style="font-size:12px;color:var(--hw-muted);margin-top:4px;">
                    @msg.SentOnUtc.ToLocalTime().ToString("dd MMM yyyy HH:mm")
                </div>

                <div style="margin-top:10px;white-space:pre-wrap;">
                    @msg.MessageText
                </div>

                @if (msg.IsFormShareMessage && msg.FormTitle != null)
                {
                    <div style="margin-top:12px;padding:10px 12px;border-radius:10px;background:#fff;border:1px solid var(--hw-border);">
                        <div style="font-weight:700;color:var(--hw-dark);">
                            <i class="bi bi-file-earmark-text"></i> Attached Form
                        </div>
                        <div style="font-size:13px;color:var(--hw-muted);margin-top:4px;">
                            @msg.FormTitle
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

@if (Model.Status == "Open")
{
    <div class="hw-card" style="margin-top:18px;">
        <div class="hw-card-head">
            <div class="hw-card-icon green">
                <i class="bi bi-reply"></i>
            </div>

            <div>
                <div class="hw-card-title">Reply</div>
            </div>
        </div>

        <div class="hw-card-body">
            <form asp-action="Reply" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="ThreadId" />

                <div class="hw-field">
                    <label class="hw-field-label" asp-for="AdminChatProfileId">Reply As</label>
                    <select asp-for="AdminChatProfileId" asp-items="Model.AdminChatProfiles" class="hw-select">
                        <option value="">— Select chatter name —</option>
                    </select>
                    <span asp-validation-for="AdminChatProfileId" class="hw-field-error"></span>
                </div>

                <div class="hw-field">
                    <label class="hw-field-label" asp-for="ReplyText">Message</label>
                    <textarea asp-for="ReplyText" rows="5" class="hw-input"></textarea>
                    <span asp-validation-for="ReplyText" class="hw-field-error"></span>
                </div>

                <div style="margin-top:20px">
                    <button class="hw-btn-primary">
                        <i class="bi bi-send"></i>
                        Send Reply
                    </button>
                </div>
            </form>
        </div>
    </div>

    <div class="hw-card" style="margin-top:18px;">
        <div class="hw-card-head">
            <div class="hw-card-icon gold">
                <i class="bi bi-file-earmark-text"></i>
            </div>

            <div>
                <div class="hw-card-title">Send Form to Beneficiary</div>
                <div class="hw-card-sub">Share a published form directly in this conversation.</div>
            </div>
        </div>

        <div class="hw-card-body">
            <form asp-action="SendForm" method="post">
                @Html.AntiForgeryToken()

                <input type="hidden" asp-for="SendForm.ThreadId" />

                <div class="hw-field">
                    <label class="hw-field-label" asp-for="SendForm.AdminChatProfileId">Send As</label>
                    <select asp-for="SendForm.AdminChatProfileId" asp-items="Model.SendForm.AdminChatProfiles" class="hw-select">
                        <option value="">— Select chatter name —</option>
                    </select>
                </div>

                <div class="hw-field">
                    <label class="hw-field-label" asp-for="SendForm.FormPublishId">Published Form</label>
                    <select asp-for="SendForm.FormPublishId" asp-items="Model.SendForm.PublishedForms" class="hw-select">
                        <option value="">— Select published form —</option>
                    </select>
                </div>

                <div class="hw-field">
                    <label class="hw-field-label" asp-for="SendForm.Note">Optional Note</label>
                    <textarea asp-for="SendForm.Note" rows="4" class="hw-input"></textarea>
                </div>

                <div style="margin-top:20px">
                    <button class="hw-btn-primary">
                        <i class="bi bi-send-check"></i>
                        Send Form
                    </button>
                </div>
            </form>
        </div>
    </div>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}