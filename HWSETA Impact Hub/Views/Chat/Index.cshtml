@model HWSETA_Impact_Hub.Models.ViewModels.Chats.ChatInboxVm
@{
    ViewData["Title"] = "Inbox";
}

<link rel="stylesheet" href="~/css/beneficiarycreatecss.css" />

<div style="display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:24px;flex-wrap:wrap;gap:12px;">
    <div>
        <div class="hw-page-eyebrow"><i class="bi bi-chat-dots me-1"></i>Communication Centre</div>
        <h1 class="hw-page-title">Email <span>Chat Inbox</span></h1>
        <p class="hw-page-desc">Track two-way communication between beneficiaries and administrators.</p>
    </div>
    <a asp-action="Create" class="hw-btn-primary">
        <i class="bi bi-plus-circle"></i> New Conversation
    </a>
</div>

<div class="hw-card">
    <div class="hw-card-head">
        <div class="hw-card-icon green"><i class="bi bi-inbox"></i></div>
        <div>
            <div class="hw-card-title">Inbox</div>
            <div class="hw-card-sub">Open and recent communication threads</div>
        </div>
    </div>
    <div class="hw-card-body">
        @if (!Model.Threads.Any())
        {
            <div class="hw-field-hint">No conversations yet.</div>
        }
        else
        {
            <div style="display:flex;flex-direction:column;gap:12px;">
                @foreach (var t in Model.Threads)
                {
                    <a asp-action="Thread" asp-route-id="@t.ThreadId"
                       style="display:block;text-decoration:none;color:inherit;border:1.5px solid var(--hw-border);border-radius:14px;padding:16px 18px;background:#fff;">
                        <div style="display:flex;justify-content:space-between;gap:12px;align-items:flex-start;flex-wrap:wrap;">
                            <div>
                                <div style="font-weight:800;color:var(--hw-dark);">@t.Subject</div>
                                <div style="font-size:12px;color:var(--hw-muted);margin-top:4px;">
                                    <strong>@t.BeneficiaryName</strong>
                                </div>
                                <div style="font-size:12px;color:var(--hw-muted);margin-top:6px;">
                                    <strong>@t.LastSender:</strong> @t.LastMessagePreview
                                </div>
                            </div>
                            <div style="text-align:right;">
                                <div style="font-size:11px;font-weight:700;color:var(--hw-muted);">@t.LastMessageOnUtc.ToLocalTime().ToString("dd MMM yyyy HH:mm")</div>
                                <div style="margin-top:6px;">
                                    <span class="hw-status-badge @(t.Status == "Open" ? "active" : "inactive")">@t.Status</span>
                                </div>
                                @if (t.HasUnreadAdminMessage || t.HasUnreadBeneficiaryMessage)
                                {
                                    <div style="margin-top:6px;font-size:11px;font-weight:700;color:var(--hw-red);">
                                        Unread
                                    </div>
                                }
                            </div>
                        </div>
                    </a>
                }
            </div>
        }
    </div>
</div>